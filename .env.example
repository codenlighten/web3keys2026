# web3keys server configuration

NODE_ENV=production
PORT=3000

# Public domain for paymail handles (user@WALLET_DOMAIN) and the base URL in paymail docs
WALLET_DOMAIN=web3keys.com
BASE_URL=https://web3keys.com

# BSV network: livenet | testnet
BSV_NETWORK=livenet

# SQLite database file
DB_FILE=/var/lib/web3keys/web3keys.db

# Session signing secret (REQUIRED in production) — generate with: openssl rand -hex 32
JWT_SECRET=
SESSION_TTL_MS=1800000

# OTP
OTP_TTL_MS=600000

# SMTP for nodemailer (REQUIRED in production for OTP delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=web3keys <no-reply@web3keys.com>

# Off-site DB backups to DigitalOcean Spaces (S3-compatible). Optional — if unset,
# backups stay local only. Used by deploy/web3keys-backup.sh.
DO_SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_FOLDER=/web3keys

# Client-side backup encryption (defense in depth). age recipient PUBLIC key; the
# server encrypts to it and cannot decrypt. Keep the matching private identity OFF-box.
# Generate with: age-keygen -o identity.txt  (the "Public key:" line is the recipient)
# If unset, backups are stored as plain gzip.
BACKUP_AGE_RECIPIENT=
