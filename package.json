{
  "name": "web3keys",
  "version": "0.2.0",
  "private": true,
  "description": "web3keys — production BSV wallet (threshold custody, paymail, multi-node)",
  "workspaces": [
    "packages/shared",
    "packages/wallet-core",
    "packages/server",
    "packages/worker",
    "packages/web"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "test:core": "npm run test -w @web3keys/wallet-core",
    "test:server": "npm run test -w @web3keys/server",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "node packages/server/src/index.js",
    "server:dev": "NODE_ENV=development node packages/server/src/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2"
  },
  "license": "MIT"
}
